APP_NAME=BIST Agentic RAG
APP_ENV=dev
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
API_HOST_PORT=18000

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=bist_chunks
MILVUS_DIM=384
MILVUS_STRICT_MODE=false

REDIS_URL=redis://localhost:6379/0

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-3-lite
NOMIC_API_KEY=
NOMIC_EMBEDDING_MODEL=nomic-embed-text-v1.5
EMBEDDING_PROVIDER=local

DEFAULT_LANGUAGE=bilingual
MAX_TOP_K=8
SESSION_TTL_HOURS=24
DISCLAIMER=This system does not provide investment advice.
TRACE_STORE_SIZE=300
CRAWLER_USER_AGENT=bist-agentic-rag/1.0
